{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Helm",
  "version": "0.0.1",
  "identifier": "com.docshield.helm",
  "build": {
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Helm",
        "width": 1440,
        "height": 900,
        "minWidth": 720,
        "minHeight": 480,
        "decorations": true,
        "transparent": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "fullscreen": false,
        "resizable": true,
        "backgroundColor": "#0B0C0E"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png"
    ],
    "category": "DeveloperTool",
    "shortDescription": "A modern terminal that happens to use tmux.",
    "longDescription": "Helm is a personal, GUI-first terminal that uses tmux as its persistence engine."
  }
}
